# ═══════════════════════════════════════════════════════
#  AgenXNodes — .gitignore
# ═══════════════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Environment & Secrets (CRITICAL) ────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env*.local
*.pem

# ─── Build Output ────────────────────────────────────
dist/
dist-ssr/
build/
out/
.next/
.nuxt/

# ─── Logs ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS Files ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor / IDE ────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
*.sublime-workspace
*.sublime-project
*.code-workspace

# ─── Testing & Coverage ─────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Misc ─────────────────────────────────────────────
*.local
*.tsbuildinfo
.cache/
.parcel-cache/
.vercel/
.netlify/
